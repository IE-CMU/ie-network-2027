---
import { type Locale } from '@utils/locale'
import { getRelativeLocaleUrl } from 'astro:i18n'

interface Props {
  locale: Locale
}
const { locale } = Astro.props
---

<main>
  <!-- Hero Section -->
  <section
    class="text-white py-20"
    style="background-image: linear-gradient(to right, rgba(158, 118, 180, 0.7), rgba(111, 76, 128, 0.7)), url('/tech2.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat;"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl font-bold mb-4">
        {
          locale === 'th'
            ? 'การประชุมวิชาการข่ายงานวิศวกรรมอุตสาหการ ครั้งที่ 45'
            : 'The 45th Industrial Engineering Network Conference'
        }
      </h1>
      <p class="text-xl mb-4">
        {
          locale === 'th'
            ? '"ขับเคลื่อนวิศวกรรมอุตสาหการในยุคแห่งความไม่แน่นอน"'
            : '"Shaping Industrial Engineering in an Era of Uncertainty"'
        }
      </p>
      <p class="text-lg mb-8">
        {locale === 'th' ? '12-14 พฤษภาคม 2570' : 'May 12-14, 2027'}
      </p>
      <p class="text-lg mb-8">
        {
          locale === 'th'
            ? 'เชียงใหม่ แกรนด์วิว โฮเทล แอนด์ คอนเวนชั่น เซ็นเตอร์'
            : 'Chiangmai Grandview Hotel & Convention Center, Chiang Mai'
        }
      </p>
      <a
        href={getRelativeLocaleUrl(locale, '/submission')}
        class="bg-yellow-500 hover:bg-yellow-600 text-gray-900 font-bold py-3 px-8 rounded-lg transition"
      >
        {locale === 'th' ? 'ส่งบทความตอนนี้' : 'Submit Paper Now'}
      </a>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-8 text-center">
        {locale === 'th' ? 'เกี่ยวกับการประชุม' : 'About the Conference'}
      </h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-xl font-bold mb-4">
            {locale === 'th' ? 'ภาพรวมการประชุม' : 'Conference Overview'}
          </h3>
          <p class="text-gray-700 mb-4">
            {
              locale === 'th'
                ? 'การประชุม IE Network 2027 เป็นการประชุมวิชาการประจำปีครั้งที่ 45 ที่จัดโดยเครือข่ายวิศวกรรมอุตสาหการ โดยรวบรวมนักวิชาการ นักวิจัย และผู้เชี่ยวชาญจากภาคอุตสาหกรรม เพื่อแลกเปลี่ยนองค์ความรู้และนวัตกรรมด้านวิศวกรรมอุตสาหการ'
                : 'The IE Network 2027 Conference is the 45th annual conference organized by the Industrial Engineering Network. It brings together academics, researchers, and industry professionals to share knowledge and innovations in Industrial Engineering.'
            }
          </p>
          <p class="text-gray-700 mb-4">
            {
              locale === 'th'
                ? 'การประชุมนี้จัดขึ้นเป็นประจำทุกปีมาอย่างต่อเนื่องมากกว่า 20 ปี เพื่อเป็นเวทีสำหรับการแลกเปลี่ยนผลงานวิจัยและแนวปฏิบัติที่ดีในสาขาวิศวกรรมอุตสาหการ'
                : 'The conference has been held annually for over 20 years, providing a platform for the exchange of research findings and best practices in the field of Industrial Engineering.'
            }
          </p>
        </div>
        <div>
          <h3 class="text-xl font-bold mb-4">
            {locale === 'th' ? 'เกี่ยวกับ IE Network' : 'About IE Network'}
          </h3>
          <p class="text-gray-700 mb-4">
            {
              locale === 'th'
                ? 'เครือข่ายวิศวกรรมอุตสาหการ (IE Network) ก่อตั้งขึ้นในเดือนตุลาคม พ.ศ. 2525 โดยได้รับการสนับสนุนจากวิศวกรรมสถานแห่งประเทศไทย ปัจจุบันมีสถาบันสมาชิกมากกว่า 40 แห่งทั่วประเทศ และมีบทบาทสำคัญในการส่งเสริมความร่วมมือและการแลกเปลี่ยนองค์ความรู้ด้านวิศวกรรมอุตสาหการ'
                : 'The Industrial Engineering Network (IE Network) was founded in October 1982 with support from the Engineering Institute of Thailand. With over 40 member institutions throughout Thailand, it serves as a leading organization for fostering collaboration and knowledge exchange in the field of Industrial Engineering.'
            }
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-12 text-center">
        {locale === 'th' ? 'เมนูลัด' : 'Quick Navigation'}
      </h2>
      <div class="grid md:grid-cols-4 gap-6">
        <a
          href={getRelativeLocaleUrl(locale, '/conference-topics')}
          class="bg-[#9E76B4] hover:bg-[#8a5fa0] text-white p-6 rounded-lg text-center transition transform hover:scale-105"
        >
          <h3 class="text-xl font-bold mb-2">
            {locale === 'th' ? 'หัวข้อการประชุม' : 'Conference Topics'}
          </h3>
          <p class="text-sm">
            {locale === 'th' ? 'สำรวจสาขาการวิจัย' : 'Explore research areas'}
          </p>
        </a>
        <a
          href={getRelativeLocaleUrl(locale, '/important-dates')}
          class="bg-[#9E76B4] hover:bg-[#8a5fa0] text-white p-6 rounded-lg text-center transition transform hover:scale-105"
        >
          <h3 class="text-xl font-bold mb-2">
            {locale === 'th' ? 'กำหนดการสำคัญ' : 'Important Dates'}
          </h3>
          <p class="text-sm">
            {locale === 'th' ? 'กำหนดส่งที่สำคัญ' : 'Key deadlines'}
          </p>
        </a>
        <a
          href={getRelativeLocaleUrl(locale, '/submission')}
          class="bg-[#9E76B4] hover:bg-[#8a5fa0] text-white p-6 rounded-lg text-center transition transform hover:scale-105"
        >
          <h3 class="text-xl font-bold mb-2">
            {locale === 'th' ? 'การส่งบทความ' : 'Submission'}
          </h3>
          <p class="text-sm">
            {locale === 'th' ? 'ส่งบทความของคุณ' : 'Submit your paper'}
          </p>
        </a>
        <a
          href={getRelativeLocaleUrl(locale, '/contact')}
          class="bg-[#9E76B4] hover:bg-[#8a5fa0] text-white p-6 rounded-lg text-center transition transform hover:scale-105"
        >
          <h3 class="text-xl font-bold mb-2">
            {locale === 'th' ? 'ข้อมูลติดต่อ' : 'Contact Info'}
          </h3>
          <p class="text-sm">
            {locale === 'th' ? 'ติดต่อเรา' : 'Get in touch'}
          </p>
        </a>
      </div>
    </div>
  </section>
</main>
