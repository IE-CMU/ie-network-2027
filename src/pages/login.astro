---
import Layout from '../layouts/Layout.astro'
import { auth } from '../lib/auth'
import LoginVue from '@/components/auth/LoginVue.vue'
import MagicLinkVue from '@/components/auth/MagicLinkVue.vue'

let session = null
try {
  session = await auth.api.getSession({
    headers: Astro.request.headers,
  })
  console.log('Session:', session)
} catch (error) {
  console.error('Error fetching session:', error)
}

// Disable prerendering for this page
export const prerender = false
---

<Layout title="Login">
  <LoginVue client:load />
  <MagicLinkVue client:load />
  <button id="add-queue-btn" class="btn">Add Queue</button>
  <script>
    import { actions } from 'astro:actions'

    const btn = document.getElementById('add-queue-btn')
    if (!btn) {
      console.error('Add Queue button not found')
    }
    btn?.addEventListener('click', async () => {
      // Call the action
      const { data, error } = await actions.addQueue()
      console.log('Action response:', { data, error })
      if (error) {
        alert(`Queue action failed: ${error.message}`)
        return
      }

      alert(`Enqueued on ${data.target} with jobs ${data.jobIds.join(', ')}`)
    })
  </script>
</Layout>
