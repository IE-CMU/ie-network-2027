---
import Layout from '../layouts/Layout.astro'
import { auth } from '../utils/auth'
let session = null
try {
  session = await auth.api.getSession({
    headers: Astro.request.headers,
  })
  console.log('Session:', session)
} catch (error) {
  console.error('Error fetching session:', error)
}

// Disable prerendering for this page
export const prerender = false
---

<Layout title="Login">
  <main>
    <div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-lg shadow-md">
      <h1 class="text-2xl font-bold mb-4">Login</h1>
      <p class="mb-4">Please log in to access the conference dashboard.</p>

      <form>
        <input
          type="email"
          placeholder="Email"
          class="w-full mb-4 px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <input
          type="password"
          placeholder="Password"
          class="w-full mb-4 px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <button
          id="btn"
          type="submit"
          class="w-full bg-blue-500 text-white py-2 rounded-md hover:bg-blue-600 transition-colors duration-300"
        >
          Login
        </button>
      </form>
    </div>
  </main>

  <script>
    import { authClient } from '@/utils/auth-client'

    authClient
      .getSession()
      .then((session) => {
        console.log('Client-side session:', session)
      })
      .catch((error) => {
        console.error('Error fetching client-side session:', error)
      })

    const btn = document.getElementById('btn')
    btn &&
      btn.addEventListener('click', async (e) => {
        e.preventDefault()
        const emailObject = document.querySelector(
          'input[type="email"]'
        ) as HTMLInputElement
        const passwordObject = document.querySelector(
          'input[type="password"]'
        ) as HTMLInputElement
        const email = emailObject?.value ?? ''
        const password = passwordObject?.value ?? ''
        try {
          const { data, error } = await authClient.signIn.email({
            email,
            password,
          })
          if (error) {
            console.error('Login error:', error)
          } else {
            console.log('Login successful, session:', data)
            // Optionally, redirect to the dashboard or another page
            // window.location.href = '/dashboard'
          }
        } catch (error) {
          console.error('Unexpected error during login:', error)
        }
      })
  </script>
</Layout>
